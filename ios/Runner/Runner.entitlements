<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Universal Links: must live here (entitlements), NOT in Info.plist.
	     Host must match the reset-password link domain in the email exactly. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:starlink.ardentnetworks.com.ph</string>
	</array>
</dict>
</plist>
