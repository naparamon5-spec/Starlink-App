RewriteEngine On

# Handle CORS preflight requests
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=200,L]

# Ensure PHP files are executed
<Files "*.php">
    SetHandler application/x-httpd-php
</Files>

# Allow access to routes directory
<Directory "routes">
    Allow from all
    Require all granted
</Directory>

# Allow access to utils directory
<Directory "utils">
    Allow from all
    Require all granted
</Directory> 